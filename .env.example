# ── Required ───────────────────────────────────────────────────────────────────
# Google Civic Information API
# Get one free at: https://console.cloud.google.com/apis/library/civicinfo.googleapis.com
GOOGLE_CIVIC_API_KEY=your_google_api_key_here

# Congress.gov API
# Free registration at: https://api.congress.gov/sign-up/
CONGRESS_GOV_API_KEY=your_congress_gov_api_key_here

# ── unitedstates/congress local data ──────────────────────────────────────────
# Directory where the usc-run scraper stores downloaded data
# Install scraper: pip install unitedstates
CONGRESS_DATA_DIR=./data/congress

# ── Optional database ─────────────────────────────────────────────────────────
ENABLE_DATABASE=false

# Path for the JSON flat-file store
DB_JSON_PATH=./data/db.json

# Path for the SQLite database
DB_SQLITE_PATH=./data/civics.db

# ── OAuth 2.0 (required for Railway/SSE mode) ──────────────────────────────────
# These are values YOU define — keep them secret
OAUTH_CLIENT_ID=civics-mcp-client
OAUTH_CLIENT_SECRET=change-me-to-a-long-random-string
OAUTH_JWT_SECRET=change-me-to-a-32-plus-char-random-string

# Public URL of your Railway deployment (set automatically by Railway as RAILWAY_PUBLIC_DOMAIN)
# Override manually if needed:
# PUBLIC_URL=https://your-app.railway.app

# ── Railway sets this automatically ───────────────────────────────────────────
# PORT=3000

REFRESH_LEGISLATORS_ON_START=true